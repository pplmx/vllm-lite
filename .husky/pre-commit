#!/bin/sh
[ "$HUSKY" = "0" ] && exit 0

if command -v prek >/dev/null 2>&1; then
    prek run --stage pre-commit --config .pre-commit-config.yaml
else
    echo "prek not found, running fallback checks..."
    just fmt-check || { echo "Code is not formatted. Run: just fix"; exit 1; }
    echo "Pre-commit checks passed (fallback mode)"
fi
