# vllm-lite environment configuration
#
# Copy this file to `.env` and fill in real values for local
# development. The `.env` file is gitignored; do not commit secrets.
#
# Compose substitutes these into docker-compose.yml via `${VAR:-default}`
# references. See `docker-compose.yml` for usage.

# ──────────────────────────── Grafana ──────────────────────────────
# Username for the Grafana admin account (monitoring profile only).
GRAFANA_ADMIN_USER=admin

# Password for the Grafana admin account. Change this in production.
GRAFANA_ADMIN_PASSWORD=change-me-in-prod
